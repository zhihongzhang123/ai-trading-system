# ===========================================
# AI Trading System - 环境变量配置
# ===========================================
# 本文件包含所有可配置的环境变量
# 复制此文件为 .env 并填入实际值
# ===========================================

# ============================================
# 服务器配置
# ============================================
# Web 服务器监听端口
# 默认值：3100
PORT=3100

# ============================================
# 交易配置
# ============================================
# 交易循环间隔（分钟）
# 说明：系统每隔指定时间执行一次交易决策
# 建议配置：
#   - 超短线策略：5 分钟
#   - 波段趋势策略：20 分钟
#   - 平衡策略：10 分钟
# 默认值：20
TRADING_INTERVAL_MINUTES=20

# 最大杠杆倍数
# 说明：允许使用的最大杠杆倍数
# 范围：1-25（根据交易所限制）
# 建议：新手不超过 5 倍，经验丰富者不超过 15 倍
# 默认值：25
MAX_LEVERAGE=25

# 最大持仓数量
# 说明：同时持有的最大仓位数量
# 建议：3-5 个，避免过度分散
# 默认值：5
MAX_POSITIONS=5

# 最大持有时长（小时）
# 说明：单个仓位允许持有的最长时间
# 超过此时间后系统将强制平仓
# 建议：短线 12-24 小时，波段 36-72 小时
# 默认值：36
MAX_HOLDING_HOURS=36

# 极端止损百分比
# 说明：系统强制止损的阈值（相对于入场价）
# 达到此亏损比例时系统将强制平仓
# 建议：-15% 到 -30%
# 默认值：-30
EXTREME_STOP_LOSS_PERCENT=-30

# 交易策略
# 说明：选择交易策略类型
# 可选值：
#   - ultra-short:            超短线策略（5 分钟周期，快进快出，中高风险）
#   - swing-trend:            波段趋势策略（20 分钟周期，捕捉中期趋势，中低风险）
#   - conservative:           稳健策略（低风险低杠杆，保护本金优先）
#   - balanced:               平衡策略（风险收益平衡，默认策略）
#   - aggressive:             激进策略（高风险高杠杆，追求高收益）
#   - aggressive-team:        激进团策略（团长 + 双团员突击决策，高杠杆高仓位）
#   - rebate-farming:         返佣套利策略（5 分钟周期，高频微利交易）
#   - ai-autonomous:          AI 自主策略（完全由 AI 主导，不提供任何策略建议）
#   - multi-agent-consensus:  陪审团策略（法官 + 陪审团合议决策，高质量决策）
#   - medium-long:            中长线策略（30 分钟周期，AI 主导决策）
#   - alpha-beta:             Alpha Beta 策略（零策略指导的 AI 完全自主决策）
#   - trend-following:        趋势跟踪策略（中低风险，跟随主要趋势，让利润奔跑）
# 推荐配置组合：
#   1. 波段趋势（中长线）：TRADING_STRATEGY=swing-trend, TRADING_INTERVAL_MINUTES=20
#   2. 超短线（快进快出）：TRADING_STRATEGY=ultra-short, TRADING_INTERVAL_MINUTES=5
#   3. 稳健均衡：TRADING_STRATEGY=balanced, TRADING_INTERVAL_MINUTES=10
#   4. AI 自主（默认）：TRADING_STRATEGY=ai-autonomous, TRADING_INTERVAL_MINUTES=5
#   5. 趋势跟踪：TRADING_STRATEGY=trend-following, TRADING_INTERVAL_MINUTES=15
# 默认值：ai-autonomous
TRADING_STRATEGY=ai-autonomous

# 初始资金（USDT）
# 说明：用于计算收益率和绩效的基准资金
# 建议：与实际投入资金一致
# 默认值：1000
INITIAL_BALANCE=1000

# 账户止损线（USDT）
# 说明：账户净值低于此值时停止交易
# 建议：初始资金的 5-10%
# 默认值：50
ACCOUNT_STOP_LOSS_USDT=50

# 账户止盈线（USDT）
# 说明：账户净值达到此值时停止交易并锁定利润
# 建议：初始资金的 10-20 倍
# 默认值：20000
ACCOUNT_TAKE_PROFIT_USDT=20000

# 启动时同步配置
# 说明：启动时是否从交易所同步账户配置
# 可选值：true / false
# 默认值：true
SYNC_CONFIG_ON_STARTUP=true

# ============================================
# 数据库配置
# ============================================
# 数据库连接 URL
# 说明：支持本地 SQLite 和远程 Turso 数据库
# 本地 SQLite: file:./.voltagent/trading.db
# 远程 Turso: libsql://your-database.turso.io
# 默认值：file:./.voltagent/trading.db
DATABASE_URL=file:./.voltagent/trading.db

# ============================================
# 交易所配置
# ============================================
# 选择使用的交易所
# 可选值：gate / okx
# 默认值：gate
EXCHANGE=gate

# ============================================
# Gate.io API 配置
# ============================================
# Gate.io API 密钥（必需）
# 获取方式：登录 Gate.io -> 账户 -> API 管理 -> 创建 API 密钥
# 权限要求：读取账户信息、读取市场数据、交易权限
GATE_API_KEY=your_api_key_here

# Gate.io API 密钥（必需）
GATE_API_SECRET=your_api_secret_here

# 是否使用 Gate.io 测试网
# 说明：测试网使用模拟资金，适合策略验证
# 可选值：true / false
# 默认值：true（建议新手先使用测试网）
GATE_USE_TESTNET=true

# ============================================
# OKX API 配置
# ============================================
# OKX API 密钥（必需，当 EXCHANGE=okx 时）
# 获取方式：登录 OKX -> 用户中心 -> API -> 创建 API
# 权限要求：读取账户、读取交易数据、交易权限
OKX_API_KEY=your_okx_api_key_here

# OKX API 密钥（必需，当 EXCHANGE=okx 时）
OKX_API_SECRET=your_okx_api_secret_here

# OKX API 口令（必需，当 EXCHANGE=okx 时）
OKX_API_PASSPHRASE=your_okx_passphrase_here

# 是否使用 OKX 测试网
# 说明：测试网和正式网使用相同域名，通过 header 区分
# 可选值：true / false
# 默认值：true
OKX_USE_TESTNET=true

# ============================================
# 手动平仓密码配置
# ============================================
# 用于网页界面手动平仓功能的密码验证（必需）
# 说明：如果不设置此密码，网页平仓功能将被禁用
# 建议：设置一个强密码，不要使用 API 密钥
# 默认值：空（禁用网页平仓）
CLOSE_POSITION_PASSWORD=

# ============================================
# AI 模型配置
# ============================================
# OpenAI 兼容的 API 密钥（必需）
# 说明：支持 OpenAI、OpenRouter 或其他兼容供应商
# OpenRouter: https://openrouter.ai/keys
# OpenAI: https://platform.openai.com/api-keys
# DeepSeek: https://platform.deepseek.com/
OPENAI_API_KEY=your_api_key_here

# OpenAI 兼容的 API 基础地址（可选）
# 说明：指定 AI 模型的 API 端点
# 常用供应商：
#   - OpenRouter: https://openrouter.ai/api/v1
#   - OpenAI: https://api.openai.com/v1
#   - DeepSeek: https://api.deepseek.com/v1
#   - 其他兼容 OpenAI API 的供应商
# 默认值：https://openrouter.ai/api/v1
OPENAI_BASE_URL=https://openrouter.ai/api/v1

# AI 模型名称（可选）
# 说明：指定使用的 AI 模型
# 常用模型：
#   - OpenRouter: 
#     - deepseek/deepseek-v3.2-exp（推荐，性价比高）
#     - x-ai/grok-4-fast（快速响应）
#     - anthropic/claude-sonnet-4（高质量）
#   - OpenAI: gpt-4, gpt-3.5-turbo
# 注意：不同供应商的模型名称不同，请参考供应商文档
# Dashscope: deepseek-v4-pro, qwen3.6-plus, qwen3.6-max-preview
# OpenRouter: deepseek/deepseek-v3.2-exp, x-ai/grok-4-fast
# 当前配置：deepseek-v4-pro (Dashscope T0 投资分析专用)
AI_MODEL_NAME=deepseek-v4-pro

# ============================================
# Gate MCP News 配置（消息面数据）
# ============================================
# 是否启用 Gate News MCP
# 说明：启用后将获取实时加密货币快讯、交易所公告、社交情绪数据
# 可选值：true / false
# 默认值：true
#GATE_NEWS_MCP_ENABLED=true

# Gate News MCP 端点地址
# 说明：指定新闻数据源的 API 端点
# 默认值：https://api.gatemcp.ai/mcp/news
#GATE_NEWS_MCP_URL=https://api.gatemcp.ai/mcp/news

# ============================================
# 账户回撤风控配置
# ============================================
# 当账户资产相比峰值回撤达到以下百分比时的风控措施：

# 警告阈值
# 说明：达到此阈值时发出风险警告提醒
# 建议：15-25%
# 默认值：20
ACCOUNT_DRAWDOWN_WARNING_PERCENT=20

# 禁止开仓阈值
# 说明：达到此阈值时停止开新仓位，只允许平仓
# 建议：25-35%
# 默认值：30
ACCOUNT_DRAWDOWN_NO_NEW_POSITION_PERCENT=30

# 强制平仓阈值
# 说明：达到此阈值时自动平掉所有仓位，保护剩余资金
# 建议：40-60%
# 默认值：50
ACCOUNT_DRAWDOWN_FORCE_CLOSE_PERCENT=50

# ============================================
# 返佣配置
# ============================================
# 手续费返佣比例（百分比）
# 说明：返还手续费的百分比
# 获取方式：联系交易所申请返佣或使用邀请码注册
# 默认值：20
FEE_REBATE_PERCENT=20

# ============================================
# 账户记录配置
# ============================================
# 账户资产记录间隔（分钟）
# 说明：定期记录账户资产到数据库，生成资产曲线
# 注意：系统还会在账户净值创新高时实时记录（10 秒检查周期）
# 建议：1-5 分钟
# 默认值：1
ACCOUNT_RECORD_INTERVAL_MINUTES=1

# ============================================
# 日志配置
# ============================================
# 日志级别
# 可选值：error / warn / info / debug
# 建议：生产环境使用 info，调试时使用 debug
# 默认值：info
#LOG_LEVEL=info

# 日志输出格式
# 可选值：json / pretty
# 建议：生产环境使用 json，开发环境使用 pretty
# 默认值：pretty
#LOG_FORMAT=pretty

# ============================================
# Telegram 告警通知配置
# ============================================
# 是否启用 Telegram 通知
# 说明：启用后系统将通过 Telegram Bot 推送关键事件（止损、止盈、风控拦截、系统启停等）
# 获取 Bot Token: 与 @BotFather 对话创建新 Bot
# 获取 Chat ID: 向 @userinfobot 发送消息获取你的 Chat ID
# 可选值：true / false
# 默认值：false
TELEGRAM_ENABLED=false

# Telegram Bot Token
# 格式：123456789:ABCdefGHIjklMNOpqrsTUVwxyz
TELEGRAM_BOT_TOKEN=

# Telegram Chat ID
# 个人: 纯数字（如 123456789）
# 群组: 负数（如 -1001234567890）
TELEGRAM_CHAT_ID=

# ============================================
# 高级风控配置（新增 v2.0）
# ============================================
# 日亏损限制（百分比）
# 说明：当日累计亏损达到此百分比时，禁止开新仓位
# 建议：3-5%
# 默认值：5
DAILY_LOSS_LIMIT_PERCENT=5

# 最大连续亏损次数
# 说明：连续亏损达到此次数后，进入冷却期
# 建议：2-3 次
# 默认值：2
MAX_CONSECUTIVE_LOSSES=2

# 冷却期时长（分钟）
# 说明：触发连续亏损冷却后的暂停时间
# 建议：60-180 分钟
# 默认值：120
COOLDOWN_MINUTES=120

# 恢复模式目标倍数
# 说明：账户恢复期间，达到此倍数后退出恢复模式
# 建议：1.3-1.5
# 默认值：1.5
RECOVERY_TARGET_MULTIPLE=1.5

# 恢复模式最大仓位百分比
# 说明：恢复期间，单笔交易占总资金的最大比例
# 建议：5-10%
# 默认值：8
RECOVERY_MAX_POSITION_PERCENT=8

# 恢复模式最大杠杆
# 说明：恢复期间允许使用的最大杠杆
# 建议：1-2
# 默认值：2
RECOVERY_MAX_LEVERAGE=2

# 最低账户余额（USDT）
# 说明：账户余额低于此值时禁止开仓
# 建议：根据实际资金量设置
# 默认值：30
MIN_ACCOUNT_BALANCE=30

# 单周期最大亏损次数
# 说明：一个交易周期内最多允许亏损的交易次数
# 建议：1-2
# 默认值：2
MAX_LOSS_PER_CYCLE=2

# 紧急停止开关
# 说明：设置为 true 时立即停止所有交易
# 可选值：true / false
# 默认值：false
EMERGENCY_STOP=false
